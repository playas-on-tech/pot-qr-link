generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id        String   @id @default(cuid())
  name      String?
  lastName  String?
  company   String?
  jobTitle  String?
  phone     String?
  email     String?
  links     Json?
  photo     Bytes?
  photoMime String?
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
